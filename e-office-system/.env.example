# Copy this file to `.env` and fill in real values.
# Never commit real secrets (passwords, API keys, tokens).

# Server Config
PORT=4000
NODE_ENV=development

# Database Config (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=maharashtra_mandal_db
DB_DIALECT=mysql

# Keep it low for local testing so you don't exhaust your local machine's ports
DB_POOL_MAX=5
DB_POOL_MIN=1

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6379

FRONTEND_URL=http://localhost:5173

# Security (JWT)
JWT_SECRET=
JWT_EXPIRES_IN=1d

# Storage (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=e-office-files

# --- EMAIL CONFIGURATION (Nodemailer) ---
# Use your company email SMTP details here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME="Maharashtra Mandal e-Office"

# --- SMS GATEWAY CONFIGURATION (DLT) ---
# Fill these using your vendor docs
SMS_API_URL=
SMS_API_KEY=
SMS_USERNAME=
DLT_TE_ID=
DLT_PE_ID=
DLT_SENDER_ID=

# Admin Seeder Credentials
ADMIN_FULL_NAME=Super Admin
ADMIN_PHONE=9876543210
ADMIN_EMAIL=admin@maharashtramandal.com
ADMIN_PASSWORD=
ADMIN_PIN=1234

FILE_MAX_SIZE_MB=5
